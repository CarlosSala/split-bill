# .gitignore para proyectos de Android Studio

# Gradle
.gradle/
build/
local.properties
*.log

# Android Studio
.idea/
*.iml

# Android Studio 3.1+ generated content
captures/
.externalNativeBuild/
.cxx/

# IntelliJ IDEA
*.iws
*.ipr

# Built application files
*.apk
*.ap_

# Files for the Dalvik VM
*.dex

# Java class files
*.class

# Generated files
gen/
out/

# Gradle Wrapper
!gradle/wrapper/gradle-wrapper.jar

# Compiled native libraries
*.o
*.so
*.obj
*.dSYM/

# Proguard
proguard/
*.pro

# Android profiling
*.hprof

# Google Services (JSON file containing API keys and other sensitive information)
google-services.json

# Android Keystore files (private keys)
*.jks
*.keystore

# Eclipse project files
.classpath
.project
.settings/

# OS-specific files
.DS_Store
Thumbs.db

# VS Code
.vscode/

# Kotlin
*.kotlin_module

# Maven/Gradle cache
~/.m2/
~/.gradle/

# CI/CD files
*.ci/
*.cd/
